{
    "version": 2,
    "buildCommand": "cd client && npm ci && npm run build",
    "outputDirectory": "client/dist",
    "rewrites": [
        {
            "source": "/documents",
            "destination": "/index.html"
        },
        {
            "source": "/documents/(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/reports",
            "destination": "/index.html"
        },
        {
            "source": "/reports/(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/settings",
            "destination": "/index.html"
        },
        {
            "source": "/settings/(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/help",
            "destination": "/index.html"
        },
        {
            "source": "/help/(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/notifications",
            "destination": "/index.html"
        },
        {
            "source": "/notifications/(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/tasks",
            "destination": "/index.html"
        },
        {
            "source": "/tasks/(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/session-manager",
            "destination": "/index.html"
        },
        {
            "source": "/session-manager/(.*)",
            "destination": "/index.html"
        }
    ]
}
