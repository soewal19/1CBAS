{
    "version": 2,
    "buildCommand": "cd client && npm run build",
    "outputDirectory": "client/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "server/api/vercel-serverless-shim.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}